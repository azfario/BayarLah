# Copy your real app secrets from .env.local. docker-compose.demo.yml reads
# .env.local directly, while this file documents Docker-friendly values.

# App/worker -> OpenWA Gateway inside Docker network
OPENWA_API_BASE_URL=http://openwa-api:2785/api
OPENWA_API_KEY=dev-admin-key

# Reminder poller defaults
WHATSAPP_LOG_EMPTY_POLLS=true
WHATSAPP_WORKER_INTERVAL_MS=5000
WHATSAPP_RETRY_DELAY_MS=60000
WHATSAPP_MAX_PER_RUN=20
