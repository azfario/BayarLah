# Copy your real secrets from .env.local. docker-compose.demo.yml reads .env.local
# directly, while this file documents Docker-friendly values.

# App -> worker inside Docker network
WHATSAPP_WORKER_BASE_URL=http://whatsapp-worker:3010
WHATSAPP_WORKER_API_TOKEN=dev-secret

# Worker container defaults
WHATSAPP_WORKER_API_PORT=3010
WHATSAPP_SESSION_DATA_PATH=/app/workers/whatsapp/sessions
WHATSAPP_CHROME_PATH=/usr/bin/chromium
WHATSAPP_HEADLESS=true
WHATSAPP_EZQR=false
WHATSAPP_LOG_EMPTY_POLLS=true
WHATSAPP_WORKER_INTERVAL_MS=5000
WHATSAPP_RETRY_DELAY_MS=60000
WHATSAPP_MAX_PER_RUN=20
