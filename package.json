{
  "name": "hackathon-starter",
  "version": "0.1.0",
  "private": true,
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:demo": "node scripts/dev-demo.mjs",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "docker:demo": "docker compose -f docker-compose.demo.yml up --build",
    "docker:worker": "docker compose -f docker-compose.worker.yml up --build",
    "docker:novacloud": "docker compose -f docker-compose.novacloud.yml up -d --build",
    "whatsapp:worker": "npm --prefix workers/whatsapp run start"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.39.3",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.105.1",
    "next": "15.5.15",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "prisma": "^5.22.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
